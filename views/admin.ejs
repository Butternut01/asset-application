<!DOCTYPE html>
<html>
<head>
  <title>Admin Panel</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
  <div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
      <h1>Admin Panel</h1>
      <button id="logout-btn" class="btn btn-outline-danger">Logout</button>
    </div>
    <div class="d-flex align-items-center gap-3 mb-3">
      <div class="search-container">
        <input type="text" id="adminSearchInput" class="form-control" placeholder="Search by inventory number...">
        <button id="adminSearchBtn" class="btn btn-primary">Найти</button>
      </div>
    </div>
    
    <div id="admin-content">
      <h3>Inventory Management</h3>
      <div class="table-responsive">
        <table class="table table-striped table-hover">
          <thead class="table-dark">
            <tr>
              <th>Status</th>
              <th>Inventory Number</th>
              <th>Old Inventory Number</th>
              <th>Description</th>
              <th>User</th>
              <th>Location</th>
              <th>Responsible Person</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody id="adminTableBody">
            <!-- Admin inventory items will be loaded here -->
          </tbody>
        </table>
      </div>
      
      <nav aria-label="Page navigation">
        <ul class="pagination justify-content-center" id="adminPagination">
          <!-- Pagination will be loaded here -->
        </ul>
      </nav>
    </div>
  </div>
  
  <script src="/js/admin.js"></script>
</body>
</html>
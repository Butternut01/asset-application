<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Дашборд — Система инвентаризации</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
  <style>
    :root {
      --primary: #4361ee;
      --success: #2dc653;
      --warning: #f4a261;
      --danger: #e63946;
      --info: #4cc9f0;
      --bg: #f0f2f5;
      --card-bg: #ffffff;
      --text-muted: #6c757d;
    }

    body {
      background: var(--bg);
      font-family: 'Segoe UI', system-ui, sans-serif;
    }

    /* ── Navbar ── */
    .dash-navbar {
      background: #1e1e2e;
      padding: 0.75rem 2rem;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
    .dash-navbar .brand {
      color: #fff;
      font-weight: 700;
      font-size: 1.1rem;
      text-decoration: none;
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }
    .dash-navbar .nav-links a {
      color: rgba(255,255,255,0.7);
      text-decoration: none;
      margin-left: 1.5rem;
      font-size: 0.9rem;
      transition: color .2s;
    }
    .dash-navbar .nav-links a:hover, .dash-navbar .nav-links a.active {
      color: #fff;
    }

    /* ── Page wrapper ── */
    .page-wrapper {
      max-width: 1400px;
      margin: 0 auto;
      padding: 2rem 1.5rem;
    }

    /* ── KPI cards ── */
    .kpi-card {
      background: var(--card-bg);
      border-radius: 16px;
      padding: 1.5rem;
      box-shadow: 0 2px 12px rgba(0,0,0,0.06);
      display: flex;
      align-items: center;
      gap: 1.25rem;
      transition: transform .2s, box-shadow .2s;
    }
    .kpi-card:hover {
      transform: translateY(-3px);
      box-shadow: 0 6px 24px rgba(0,0,0,0.10);
    }
    .kpi-icon {
      width: 56px;
      height: 56px;
      border-radius: 14px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.6rem;
      flex-shrink: 0;
    }
    .kpi-icon.blue   { background: #e8ecff; color: var(--primary); }
    .kpi-icon.green  { background: #e6f9ed; color: var(--success); }
    .kpi-icon.orange { background: #fff3e5; color: var(--warning); }
    .kpi-icon.red    { background: #fdecea; color: var(--danger); }
    .kpi-icon.teal   { background: #e0f7fe; color: var(--info); }

    .kpi-label {
      font-size: 0.8rem;
      color: var(--text-muted);
      margin-bottom: 0.2rem;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }
    .kpi-value {
      font-size: 1.8rem;
      font-weight: 700;
      line-height: 1;
      color: #1e1e2e;
    }

    /* ── Chart cards ── */
    .chart-card {
      background: var(--card-bg);
      border-radius: 16px;
      padding: 1.5rem;
      box-shadow: 0 2px 12px rgba(0,0,0,0.06);
      height: 100%;
    }
    .chart-card h6 {
      font-weight: 600;
      color: #1e1e2e;
      margin-bottom: 1.25rem;
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }
    .chart-card h6 i {
      color: var(--primary);
    }
    .chart-wrapper {
      position: relative;
      height: 280px;
    }

    /* ── Recent table ── */
    .recent-card {
      background: var(--card-bg);
      border-radius: 16px;
      padding: 1.5rem;
      box-shadow: 0 2px 12px rgba(0,0,0,0.06);
    }
    .recent-card h6 {
      font-weight: 600;
      color: #1e1e2e;
      margin-bottom: 1.25rem;
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }
    .recent-card h6 i { color: var(--primary); }

    .status-badge {
      font-size: 0.75rem;
      padding: 0.25rem 0.65rem;
      border-radius: 20px;
      font-weight: 500;
    }

    /* ── Loading spinner ── */
    .dash-spinner {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      height: 60vh;
      gap: 1rem;
      color: var(--text-muted);
    }
    .dash-spinner .spinner-border { width: 3rem; height: 3rem; color: var(--primary); }
  </style>
</head>
<body>

  <!-- Navbar -->
  <nav class="dash-navbar">
    <a href="/" class="brand"><i class="bi bi-box-seam"></i> InventoryDB</a>
    <div class="nav-links">
      <a href="/">Таблица</a>
      <a href="/dashboard" class="active">Дашборд</a>
      <a href="/admin">Управление</a>
      <a href="#" id="logoutBtn"><i class="bi bi-box-arrow-right"></i> Выйти</a>
    </div>
  </nav>

  <!-- Loading state -->
  <div class="dash-spinner" id="loadingState">
    <div class="spinner-border" role="status"></div>
    <span>Загрузка аналитики...</span>
  </div>

  <!-- Main content (hidden until data loads) -->
  <div class="page-wrapper d-none" id="mainContent">

    <!-- Page header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
      <div>
        <h1 class="mb-1 fs-3 fw-bold" style="color:#1e1e2e">Аналитический дашборд</h1>
        <p class="text-muted mb-0 small">Обзор инвентаря предприятия ТОО «Казахмыс Барлау»</p>
      </div>
      <button class="btn btn-outline-secondary btn-sm" onclick="loadStats()">
        <i class="bi bi-arrow-clockwise me-1"></i>Обновить
      </button>
    </div>

    <!-- KPI row -->
    <div class="row g-3 mb-4" id="kpiRow">
      <!-- Filled by JS -->
    </div>

    <!-- Charts row -->
    <div class="row g-3 mb-4">
      <!-- Pie: by status -->
      <div class="col-md-4">
        <div class="chart-card">
          <h6><i class="bi bi-pie-chart-fill"></i>По статусу</h6>
          <div class="chart-wrapper">
            <canvas id="statusChart"></canvas>
          </div>
        </div>
      </div>
      <!-- Bar: by type -->
      <div class="col-md-4">
        <div class="chart-card">
          <h6><i class="bi bi-bar-chart-fill"></i>Топ типы оборудования</h6>
          <div class="chart-wrapper">
            <canvas id="typeChart"></canvas>
          </div>
        </div>
      </div>
      <!-- Horizontal bar: by department -->
      <div class="col-md-4">
        <div class="chart-card">
          <h6><i class="bi bi-building"></i>По отделам</h6>
          <div style="overflow-y:auto; max-height:300px;">
            <div id="deptChartWrapper">
              <canvas id="deptChart"></canvas>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Department cost table + Recent items -->
    <div class="row g-3">
      <!-- Cost by department -->
      <div class="col-md-5">
        <div class="recent-card">
          <h6><i class="bi bi-currency-exchange"></i>Стоимость по отделам</h6>
          <div class="table-responsive">
            <table class="table table-sm table-hover mb-0">
              <thead>
                <tr>
                  <th>Отдел</th>
                  <th class="text-end">Единиц</th>
                  <th class="text-end">Сумма (₸)</th>
                </tr>
              </thead>
              <tbody id="deptCostTable">
                <tr><td colspan="3" class="text-muted text-center py-3">Загрузка...</td></tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>
      <!-- Recent items -->
      <div class="col-md-7">
        <div class="recent-card">
          <h6><i class="bi bi-clock-history"></i>Последние добавленные</h6>
          <div class="table-responsive">
            <table class="table table-sm table-hover mb-0">
              <thead>
                <tr>
                  <th>Инв. номер</th>
                  <th>Описание</th>
                  <th>Тип</th>
                  <th>Статус</th>
                </tr>
              </thead>
              <tbody id="recentTable">
                <tr><td colspan="4" class="text-muted text-center py-3">Загрузка...</td></tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>

  </div><!-- /page-wrapper -->

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    // ── Color palette ──
    const PALETTE = [
      '#4361ee','#2dc653','#f4a261','#e63946','#4cc9f0',
      '#7b2d8b','#f72585','#3a0ca3','#4895ef','#560bad'
    ];

    const STATUS_COLORS = {
      'В работе':      '#2dc653',
      'Списан':        '#e63946',
      'На ремонте':    '#f4a261',
      'На складе':     '#4cc9f0',
      'Утерян':        '#7b2d8b',
    };

    let statusChart, typeChart, deptChart;

    async function loadStats() {
      try {
        const res = await fetch('/admin/stats', { credentials: 'include' });
        if (res.status === 401 || res.status === 403) {
          window.location.href = '/login';
          return;
        }
        const data = await res.json();
        renderKPI(data);
        renderStatusChart(data.byStatus);
        renderTypeChart(data.byType);
        renderDeptChart(data.byDepartment);
        renderDeptTable(data.byDepartment);
        renderRecentTable(data.recentItems);
        document.getElementById('loadingState').classList.add('d-none');
        document.getElementById('mainContent').classList.remove('d-none');
      } catch (e) {
        console.error(e);
        document.getElementById('loadingState').innerHTML =
          '<i class="bi bi-exclamation-triangle fs-1 text-danger"></i><span>Ошибка загрузки данных</span>';
      }
    }

    // ── KPI Cards ──
    function renderKPI(data) {
      const kpis = [
        { icon: 'bi-boxes',            cls: 'blue',   label: 'Всего активов',      value: data.totalCount.toLocaleString('ru') },
        { icon: 'bi-cash-coin',        cls: 'teal',   label: 'Общая стоимость (₸)',value: formatMoney(data.totalCost) },
      ];

      document.getElementById('kpiRow').innerHTML = kpis.map(k => `
        <div class="col-6 col-md">
          <div class="kpi-card">
            <div class="kpi-icon ${k.cls}"><i class="bi ${k.icon}"></i></div>
            <div>
              <div class="kpi-label">${k.label}</div>
              <div class="kpi-value">${k.value}</div>
            </div>
          </div>
        </div>
      `).join('');
    }

    // ── Status Pie ──
    function renderStatusChart(byStatus) {
      const labels = byStatus.map(s => s._id || 'Не указан');
      const values = byStatus.map(s => s.count);
      const colors = labels.map(l => STATUS_COLORS[l] || PALETTE[labels.indexOf(l) % PALETTE.length]);

      if (statusChart) statusChart.destroy();
      statusChart = new Chart(document.getElementById('statusChart'), {
        type: 'doughnut',
        data: { labels, datasets: [{ data: values, backgroundColor: colors, borderWidth: 2, borderColor: '#fff' }] },
        options: {
          responsive: true, maintainAspectRatio: false,
          plugins: {
            legend: { position: 'bottom', labels: { boxWidth: 12, padding: 12, font: { size: 11 } } },
            tooltip: { callbacks: { label: ctx => ` ${ctx.label}: ${ctx.parsed} ед.` } }
          }
        }
      });
    }

    // ── Type Bar ──
    function renderTypeChart(byType) {
      const labels = byType.map(t => t._id || 'Не указан');
      const values = byType.map(t => t.count);

      if (typeChart) typeChart.destroy();
      typeChart = new Chart(document.getElementById('typeChart'), {
        type: 'bar',
        data: {
          labels,
          datasets: [{
            label: 'Количество',
            data: values,
            backgroundColor: PALETTE.slice(0, labels.length),
            borderRadius: 8,
            borderSkipped: false,
          }]
        },
        options: {
          responsive: true, maintainAspectRatio: false,
          plugins: { legend: { display: false } },
          scales: {
            y: { beginAtZero: true, grid: { color: '#f0f0f0' }, ticks: { precision: 0 } },
            x: { grid: { display: false }, ticks: { font: { size: 10 } } }
          }
        }
      });
    }

    // ── Department Horizontal Bar ──
    function renderDeptChart(byDept) {
      const labels = byDept.map(d => truncate(d._id, 20));
      const values = byDept.map(d => d.count);

      // Динамическая высота: 30px на каждый отдел, минимум 120px
      const barHeight = 30;
      const canvasHeight = Math.max(120, labels.length * barHeight);
      const wrapper = document.getElementById('deptChartWrapper');
      wrapper.style.height = canvasHeight + 'px';

      if (deptChart) deptChart.destroy();
      deptChart = new Chart(document.getElementById('deptChart'), {
        type: 'bar',
        data: {
          labels,
          datasets: [{
            label: 'Единиц',
            data: values,
            backgroundColor: '#4361ee',
            borderRadius: 6,
          }]
        },
        options: {
          indexAxis: 'y',
          responsive: true, maintainAspectRatio: false,
          plugins: { legend: { display: false } },
          scales: {
            x: { beginAtZero: true, max: 30, grid: { color: '#f0f0f0' }, ticks: { precision: 0 } },
            y: { grid: { display: false }, ticks: { font: { size: 10 } } }
          }
        }
      });
    }

    // ── Department cost table ──
    function renderDeptTable(byDept) {
      if (!byDept.length) {
        document.getElementById('deptCostTable').innerHTML =
          '<tr><td colspan="3" class="text-muted text-center py-3">Нет данных</td></tr>';
        return;
      }
      document.getElementById('deptCostTable').innerHTML = byDept.map(d => `
        <tr>
          <td>${d._id || '—'}</td>
          <td class="text-end">${d.count}</td>
          <td class="text-end">${formatMoney(d.totalCost)}</td>
        </tr>
      `).join('');
    }

    // ── Recent items ──
    function renderRecentTable(items) {
      if (!items.length) {
        document.getElementById('recentTable').innerHTML =
          '<tr><td colspan="4" class="text-muted text-center py-3">Нет данных</td></tr>';
        return;
      }
      document.getElementById('recentTable').innerHTML = items.map(item => `
        <tr>
          <td><code class="text-primary">${item.inventory_number || '—'}</code></td>
          <td>${truncate(item.description || '—', 35)}</td>
          <td>${item.type || '—'}</td>
          <td><span class="status-badge" style="background:${statusBg(item.status)};color:${statusColor(item.status)}">${item.status || '—'}</span></td>
        </tr>
      `).join('');
    }

    // ── Helpers ──
    function formatMoney(n) {
      if (!n) return '—';
      return Math.round(n).toLocaleString('ru') + ' ₸';
    }
    function truncate(s, n) {
      return s && s.length > n ? s.slice(0, n) + '…' : s;
    }
    function statusBg(s) {
      const map = { 'В работе':'#e6f9ed','На ремонте':'#fff3e5','Списан':'#fdecea','На складе':'#e0f7fe' };
      return map[s] || '#f0f0f0';
    }
    function statusColor(s) {
      const map = { 'В работе':'#2dc653','На ремонте':'#f4a261','Списан':'#e63946','На складе':'#4cc9f0' };
      return map[s] || '#666';
    }

    // Logout
    document.getElementById('logoutBtn').addEventListener('click', async (e) => {
      e.preventDefault();
      await fetch('/logout', { method: 'POST' });
      window.location.href = '/login';
    });

    // Init
    loadStats();
  </script>
</body>
</html>

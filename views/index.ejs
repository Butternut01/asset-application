<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Inventory Management System</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
      <div>
        <h1 class="mb-1">Inventory Management</h1>
        <p class="text-muted mb-0">Система управления инвентаризацией</p>
      </div>
      <div class="d-flex align-items-center gap-3">
        <div class="search-container">
          <input type="text" id="searchInput" class="form-control" placeholder="Поиск по номеру, пользователю, локации...">
          <button id="searchBtn" class="btn btn-primary">
            <i class="bi bi-search"></i>
          </button>
        </div>
        <a href="/login" class="btn btn-outline-dark">Войти в админ панель</a>
      </div>
    </div>

    <div class="table-responsive">
      <table class="table table-striped table-hover">
        <thead>
          <tr>
            <th>Статус</th>
            <th>Инвентарный номер</th>
            <th>Старый инв. номер</th>
            <th>Описание</th>
            <th>Пользователь</th>
            <th>Локация</th>
            <th>МОЛ</th>
            <th>Действия</th>
          </tr>
        </thead>
        <tbody id="inventoryTableBody">
          <!-- Inventory items will be loaded here -->
        </tbody>
      </table>
    </div>

    <nav aria-label="Page navigation">
      <ul class="pagination justify-content-center" id="pagination">
        <!-- Pagination will be loaded here -->
      </ul>
    </nav>
  </div>

  <!-- Modal for detailed view -->
  <div class="modal fade" id="detailsModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title">Детали инвентаря</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <div class="modal-body" id="modalBody">
          <!-- Details will be loaded here -->
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Закрыть</button>
        </div>
      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/flexsearch.min.js"></script>
  <script src="/js/script.js"></script>
</body>
</html>